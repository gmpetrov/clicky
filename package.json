{
  "name": "clicky",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Clicky is an AI teacher that lives as a buddy next to your cursor.",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "auth:generate": "better-auth generate --config ./auth.ts",
    "worker:dev": "npm --prefix worker run dev",
    "worker:deploy": "npm --prefix worker run deploy",
    "stripe:dev": "stripe listen --forward-to localhost:3000/api/auth/stripe/webhook"
  },
  "dependencies": {
    "@better-auth/prisma-adapter": "1.6.0",
    "@better-auth/stripe": "1.6.0",
    "@hugeicons/core-free-icons": "^4.1.1",
    "@hugeicons/react": "^1.1.6",
    "@prisma/adapter-pg": "7.7.0",
    "@prisma/client": "7.7.0",
    "better-auth": "1.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.548.0",
    "next": "16.2.2",
    "pg": "8.20.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.2.0",
    "stripe": "20.4.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@better-auth/cli": "1.4.21",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^24.6.0",
    "@types/pg": "8.20.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "eslint": "^9.37.0",
    "eslint-config-next": "16.2.2",
    "postcss": "^8.5.9",
    "prisma": "7.7.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3"
  }
}
